{
  "name": "ai-radio-echo-dashboard",
  "version": "1.0.0",
  "description": "Local development server for the AI Radio Echo HTML dashboard. Watches config.js for changes written by sync_config.py and auto-reloads the browser.",
  "private": true,
  "scripts": {
    "run:local": "python main.py --env local",
    "run:prod-db": "python main.py --env prod-db",
    "run:prod-models": "python main.py --env prod-models",
    "run:production": "python main.py --env production",
    "run:local:dry": "python main.py --env local --dry-run",
    "run:prod-db:dry": "python main.py --env prod-db --dry-run",
    "run:prod-models:dry": "python main.py --env prod-models --dry-run",
    "run:production:dry": "python main.py --env production --dry-run",
    "verify": "python verify_system.py",
    "test:integration": "python tests/integration_suite.py",
    "dashboard:serve": "browser-sync start --server --files 'config.js,*.html,*.css' --no-notify",
    "dashboard:watch": "browser-sync start --server --files 'config.js' --no-open --no-notify --logLevel silent"
  },
  "devDependencies": {
    "browser-sync": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "notes": [
    "browser-sync serves the dashboard HTML and auto-reloads whenever",
    "sync_config.py overwrites config.js with fresh episode data.",
    "Run 'npm install' once, then 'npm run dev' alongside the pipeline."
  ]
}
