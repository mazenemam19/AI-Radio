{
  "name": "ai-radio-echo",
  "version": "1.0.0",
  "description": "AI Radio Echo — automated satirical radio pipeline (AI → TTS → MP4 → YouTube)",
  "private": true,
  "scripts": {
    "start":               "python main.py --env local",
    "dry-run":             "python main.py --env local --dry-run",
    "prod":                "python main.py --env production",
    "prod:dry":            "python main.py --env production --dry-run",
    "verify":              "python verify_system.py",
    "test":                "python tests/integration_suite.py",
    "test:ci":             "python main.py --env local --dry-run",
    "setup":               "python -m pip install -r requirements.txt",
    "note:venv":           "NOTE: Use .venv/Scripts/python.exe if system python fails on pyiceberg",
    "refresh:prod-stats":  "python sync_engagement.py --env production",
    "refresh:local-stats": "python sync_engagement.py --env local",
    "update:prod-config":  "python sync_config.py --env production",
    "update:local-config": "python sync_config.py --env local",
    "dashboard:prod":      "npm run refresh:prod-stats && npm run update:prod-config && python -m http.server 8080",
    "dashboard:local":     "npm run refresh:local-stats && npm run update:local-config && python -m http.server 8080",
    "serve:prod":          "npm run update:prod-config && python -m http.server 8080",
    "serve:local":         "npm run update:local-config && python -m http.server 8080"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "radio",
    "tts",
    "podcast",
    "automation",
    "youtube",
    "gemini",
    "groq",
    "ffmpeg"
  ],
  "license": "MIT"
}
