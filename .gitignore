# AI Radio — Echo — .gitignore

# ── Required by spec ─────────────────────────────────────────────────
config.js
*.db
output/
assets/art_*

# ── Secrets ──────────────────────────────────────────────────────────
.env

# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# ── Node ─────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── OS ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
