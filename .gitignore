# AI Radio Echo — .gitignore

# ── Secrets (NEVER commit these) ──────────────────────────────────────────
.env
config.js

# ── Generated databases ───────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal

# ── Pipeline output artifacts ─────────────────────────────────────────────
output/
assets/art_*

# ── Groq TTS quota tracker ────────────────────────────────────────────────
output/.groq_usage.json

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environments ──────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Node.js ───────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ── IDE / editor ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

