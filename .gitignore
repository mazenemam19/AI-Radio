# AI Radio — Echo  |  .gitignore

# ── Secrets & credentials ─────────────────────────────────────────────────────
.env
config.js

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal

# ── Pipeline output ───────────────────────────────────────────────────────────
output/
assets/art_*

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
