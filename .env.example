# AI Radio — Echo  |  Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.
#
# Which keys are required depends on your --env flag:
#
#   local       → GEMINI_API_KEY only
#   prod-db     → GEMINI_API_KEY + SUPABASE_URL + SUPABASE_KEY
#   prod-models → GEMINI_API_KEY + GROQ_API_KEY
#   production  → all keys below


# ── AI (mandatory for all envs — Gemini is the universal fallback) ────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── AI / TTS (required for prod-models and production) ────────────────────────
GROQ_API_KEY=your_groq_api_key_here
CARTESIA_API_KEY=your_cartesia_api_key_here

# ── Database (required for prod-db and production) ────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key_here

# ── YouTube upload (required for production) ──────────────────────────────────
# OAuth2 credentials from Google Cloud Console (YouTube Data API v3)
YOUTUBE_CLIENT_ID=your_google_oauth_client_id_here
YOUTUBE_CLIENT_SECRET=your_google_oauth_client_secret_here
YOUTUBE_REFRESH_TOKEN=your_youtube_oauth_refresh_token_here

# ── Frontend dashboard ────────────────────────────────────────────────────────
# Full URL where the HTML dashboard is hosted (written into config.js)
WEBSITE_URL=https://your-dashboard-url.example.com
