# AI Radio Echo — Environment Variables
# Copy this file to .env and fill in your values.
# cp .env.example .env
#
# Which keys are required depends on your --env flag:
#
#   --env local        → GEMINI_API_KEY only
#   --env prod-db      → GEMINI_API_KEY + SUPABASE_*
#   --env prod-models  → GEMINI_API_KEY + GROQ_API_KEY
#   --env production   → all keys below
#
# dry-run mode skips AI + DB entirely, so no keys are needed:
#   python main.py --env local --dry-run   ← zero keys required (CI default)

# ── AI ─────────────────────────────────────────────────────────────────────
# Required for all non-dry-run modes. Used as primary model for local/prod-db
# and as fallback for production/prod-models.
GEMINI_API_KEY=

# Required for prod-models and production. Used for llama-3.3-70b-versatile
# completions and Groq Orpheus TTS.
GROQ_API_KEY=

# ── Database (Supabase) ────────────────────────────────────────────────────
# Required for prod-db and production.
# Find these in your Supabase project: Settings → API
SUPABASE_URL=
SUPABASE_KEY=

# ── YouTube ───────────────────────────────────────────────────────────────
# Required for production only (YouTube upload is NULL in all other envs).
# Obtain via Google Cloud Console → OAuth 2.0 → YouTube Data API v3
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── Dashboard ─────────────────────────────────────────────────────────────
# Optional. Written into config.js for metadata display on the frontend.
WEBSITE_URL=
