# AI Radio — Echo — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Required for all environments ────────────────────────────────────
# Mandatory: used as the primary AI model for local/prod-db,
# and as a fallback model for prod-models/production.
GEMINI_API_KEY=your_gemini_api_key_here

# ── Required for prod-models and production ───────────────────────────
# Primary AI (llama-3.3-70b-versatile) + Groq Orpheus TTS.
GROQ_API_KEY=your_groq_api_key_here

# ── Required for prod-db and production ──────────────────────────────
# Supabase project credentials.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key_here

# ── Required for production (YouTube upload) ──────────────────────────
# OAuth 2.0 credentials for the YouTube Data API v3.
YOUTUBE_CLIENT_ID=your_youtube_oauth_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_oauth_client_secret_here
YOUTUBE_REFRESH_TOKEN=your_youtube_oauth_refresh_token_here

# ── Optional ─────────────────────────────────────────────────────────
# Frontend URL shown in episode metadata.
WEBSITE_URL=https://your-website.com
