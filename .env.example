# AI Radio — Echo  |  Environment Variables
# Copy this file to .env and fill in your values.
# .env must NEVER be committed — it is listed in .gitignore.

# ──────────────────────────────────────────────────────────────
# REQUIRED FOR ALL ENVIRONMENTS
# ──────────────────────────────────────────────────────────────

# Google Gemini API key (local fallback AI for all envs)
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL shown in episode metadata (optional but recommended)
WEBSITE_URL=https://your-dashboard-url.example.com

# ──────────────────────────────────────────────────────────────
# REQUIRED FOR: prod-models, production
# ──────────────────────────────────────────────────────────────

# Groq API key (primary AI + Orpheus TTS in production envs)
GROQ_API_KEY=your_groq_api_key_here

# ──────────────────────────────────────────────────────────────
# REQUIRED FOR: prod-db, production
# ──────────────────────────────────────────────────────────────

# Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/service_role key
SUPABASE_KEY=your_supabase_key_here

# ──────────────────────────────────────────────────────────────
# REQUIRED FOR: production  (YouTube upload)
# ──────────────────────────────────────────────────────────────

# YouTube OAuth2 credentials
# Generate via: https://console.cloud.google.com/apis/credentials
# Scope required: https://www.googleapis.com/auth/youtube.upload
YOUTUBE_CLIENT_ID=your_youtube_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token
